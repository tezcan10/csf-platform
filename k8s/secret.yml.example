# Copy to secret.yml, fill in base64-encoded values, then: kubectl apply -f k8s/secret.yml
# Generate values:  echo -n "your-value" | base64
# secret.yml is gitignored — never commit real credentials.
apiVersion: v1
kind: Secret
metadata:
  name: pipeline-secrets
  namespace: csf-platform
type: Opaque
data:
  ANTHROPIC_API_KEY: <base64-encoded-key>
  GITHUB_TOKEN: <base64-encoded-token>
